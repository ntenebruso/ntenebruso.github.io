---
export interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
    href: string;
}

const { href, ...props } = Astro.props;

let isActive;
if (href == "/") {
    isActive = href == Astro.url.pathname;
} else {
    isActive = Astro.url.pathname.includes(href);
}
---

<a href={href} class={`no-underline text-muted-foreground`} {...props}>
    <span
        class={`transition-colors ${isActive && "active"} hover:text-foreground`}
        ><slot /></span
    >
</a>
