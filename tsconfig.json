{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "paths": {
            "@components/*": ["./src/components/*"],
            "@content/*": ["./src/content/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@lib/*": ["./src/lib/*"],
            "@plugins/*": ["./src/plugins/*"],
            "@styles/*": ["./src/styles/*"]
        }
    }
}
